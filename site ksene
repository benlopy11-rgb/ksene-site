<script>
// ── NAV SCROLL ──
window.addEventListener('scroll', () => {
  document.getElementById('navbar').style.padding = window.scrollY > 50 ? '10px 5%' : '16px 5%';
});

// ── HAMBURGER ──
function toggleMenu() {
  const ul = document.getElementById('nav-links');
  ul.style.display = ul.style.display === 'flex' ? 'none' : 'flex';
  ul.style.flexDirection = 'column';
  ul.style.position = 'absolute';
  ul.style.top = '70px'; ul.style.left = '0'; ul.style.right = '0';
  ul.style.background = 'rgba(13,6,3,.97)';
  ul.style.padding = '20px 5%';
  ul.style.borderBottom = '1px solid rgba(245,168,0,.15)';
}

// ── HORAIRE DU JOUR ──
(function() {
  const day = new Date().getDay(); // 0=dim,1=lun,...
  const map = {1:'day-0',2:'day-2',3:'day-3',4:'day-4',5:'day-5',6:'day-6',0:'day-1'};
  const el = document.getElementById(map[day]);
  if(el) {
    el.classList.add('today');
    const dayEl = el.querySelector('.horaire-day');
    if(dayEl) { dayEl.classList.add('today-label'); dayEl.textContent += ' (Aujourd\'hui)'; }
    const badge = document.createElement('span');
    badge.className = 'horaire-open'; badge.textContent = '● Ouvert';
    el.appendChild(badge);
  }
})();

// ── SCROLL REVEAL ──
const observer = new IntersectionObserver((entries) => {
  entries.forEach((e,i) => {
    if(e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i*80);
  });
}, {threshold:.1});
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ── FORMS ──
function handleReservation(e) {
  e.preventDefault();
  const btn = e.target.querySelector('button[type=submit]');
  btn.textContent = '✅ Réservation envoyée !';
  btn.style.background = 'linear-gradient(135deg,#16a34a,#15803d)';
  btn.disabled = true;
  setTimeout(() => { btn.textContent = '✅ Confirmer ma réservation'; btn.style.background=''; btn.disabled=false; e.target.reset(); }, 4000);
}

function handleContact(e) {
  e.preventDefault();
  const btn = e.target.querySelector('button[type=submit]');
  btn.textContent = '✅ Message envoyé !';
  btn.style.background = 'linear-gradient(135deg,#16a34a,#15803d)';
  btn.disabled = true;
  setTimeout(() => { btn.textContent = '📨 Envoyer le message'; btn.style.background=''; btn.disabled=false; e.target.reset(); }, 4000);
}

// ── WIDGET IA ──
(function() {
  const SYSTEM = `Tu es l'assistant IA chaleureux de K'séne, le meilleur fast-food de Lomé au Togo. Spécialités : Crêpes, Grillades et Saveurs authentiques. Adresse : Sagbado, Route Sanol, Lomé, Togo. Code Maps : 54VP+GV Lomé. Tél : +228 93 23 97 97. WhatsApp : https://wa.me/22893239797. Menu complet : https://creperieksene.com/#menu. Horaires : Mardi au Dimanche 06h00–23h00, Lundi 09h00–21h30. Services : livraison sans contact, drive, terrasse, vente à emporter, traiteur, repas sur place. Parking gratuit. Convient aux familles et groupes. Réponds en français, de façon chaleureuse et concise. Utilise des emojis avec modération.`;

  let history=[], opened=false, welcomed=false;

  window.kwToggle = function() {
    opened = !opened;
    const win = document.getElementById('ksene-widget-window');
    const btn = document.getElementById('ksene-widget-btn');
    win.classList.toggle('open', opened);
    btn.innerHTML = opened ? '✕' : '🤖<div class="widget-notif"></div>';
    if(opened && !welcomed) {
      welcomed = true;
      setTimeout(() => kwAddMsg('bot', "👋 Bienvenue chez K'séne !\n\nJe suis votre assistant IA, disponible 24h/24. Comment puis-je vous aider aujourd'hui ? 🍽️"), 300);
    }
  };

  window.kwSend = async function() {
    const input = document.getElementById('kw-input');
    const sendBtn = document.getElementById('kw-send');
    const text = input.value.trim();
    if(!text) return;
    input.value = ''; sendBtn.disabled = true;
    document.getElementById('kw-quick').style.display = 'none';
    kwAddMsg('user', text);
    history.push({role:'user', content:text});
    kwShowTyping();
    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({model:'claude-sonnet-4-20250514', max_tokens:500, system:SYSTEM, messages:history})
      });
      const data = await res.json();
      const reply = data.content?.[0]?.text || "Désolé, réessayez ou appelez le +228 93 23 97 97 😊";
      kwRemoveTyping(); kwAddMsg('bot', reply);
      history.push({role:'assistant', content:reply});
    } catch(err) {
      kwRemoveTyping();
      kwAddMsg('bot', "Une erreur s'est produite. Appelez-nous au +228 93 23 97 97 😊");
    }
    sendBtn.disabled = false; input.focus();
  };

  window.kwQuick = function(text) {
    document.getElementById('kw-input').value = text;
    kwSend();
  };

  function kwAddMsg(role, text) {
    const el = document.getElementById('kw-messages');
    const div = document.createElement('div');
    div.className = `kw-msg ${role}`;
    div.innerHTML = `<div class="kw-msg-av">${role==='bot'?'🍽️':'👤'}</div><div class="kw-bubble">${text.replace(/\n/g,'<br>')}</div>`;
    el.appendChild(div); el.scrollTop = el.scrollHeight;
  }

  function kwShowTyping() {
    const el = document.getElementById('kw-messages');
    const div = document.createElement('div');
    div.className='kw-msg bot'; div.id='kw-typing';
    div.innerHTML=`<div class="kw-msg-av">🍽️</div><div class="kw-bubble"><div class="kw-typing"><span></span><span></span><span></span></div></div>`;
    el.appendChild(div); el.scrollTop=el.scrollHeight;
  }

  function kwRemoveTyping() {
    const t=document.getElementById('kw-typing'); if(t) t.remove();
  }
})();
</script>
